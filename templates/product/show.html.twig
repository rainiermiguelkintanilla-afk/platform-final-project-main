{% extends 'base.html.twig' %}

{% block title %}Product Details
{% endblock %}

{% block body %}
	<style>
		body {
			background: #f4f7fb;
			min-height: 100vh;
			font-family: Inter, sans-serif;
		}

		.page-container {
			max-width: 750px;
			margin: 60px auto;
			padding: 0 20px;
		}

		.product-card {
			background: #fff;
			border-radius: 24px;
			padding: 40px;
			box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
		}

		.product-header {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			gap: 20px;
			margin-bottom: 32px;
			flex-wrap: wrap;
		}

		.product-title-section h1 {
			font-size: 2rem;
			font-weight: 700;
			color: #0f172a;
			margin: 0 0 10px;
		}

		.product-subtitle {
			color: #64748b;
			font-size: 0.95rem;
		}

		.product-price-badge {
			background: #ecfdf5;
			color: #059669;
			padding: 12px 18px;
			border-radius: 14px;
			font-size: 1.2rem;
			font-weight: 700;
			white-space: nowrap;
		}

		.product-details {
			display: flex;
			flex-direction: column;
			gap: 18px;
			margin-bottom: 40px;
		}

		.detail-item {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			padding: 18px 20px;
			background: #f8fafc;
			border-radius: 14px;
			gap: 20px;
		}

		.detail-label {
			font-weight: 600;
			color: #475569;
			min-width: 120px;
		}

		.detail-value {
			color: #0f172a;
			text-align: right;
			word-break: break-word;
			flex: 1;
		}

		.action-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			gap: 16px;
			flex-wrap: wrap;
		}

		.left-actions,
		.right-actions {
			display: flex;
			align-items: center;
			gap: 12px;
			flex-wrap: wrap;
		}

		.btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 8px;
			padding: 12px 20px;
			border-radius: 12px;
			text-decoration: none;
			font-weight: 600;
			transition: 0.2s ease;
			border: none;
			cursor: pointer;
		}

		.btn-back {
			background: #eef2ff;
			color: #4f46e5;
		}

		.btn-back:hover {
			background: #e0e7ff;
		}

		.btn-edit {
			background: #4f46e5;
			color: white;
			box-shadow: 0 4px 12px rgba(79, 70, 229, 0.18);
		}

		.btn-edit:hover {
			background: #4338ca;
			transform: translateY(-1px);
		}

		.delete-form button {
			background: #ef4444;
			color: white;
			border: none;
			border-radius: 12px;
			padding: 12px 20px;
			font-weight: 600;
			cursor: pointer;
			transition: 0.2s ease;
			box-shadow: 0 4px 12px rgba(239, 68, 68, 0.18);
		}

		.delete-form button:hover {
			background: #dc2626;
		}

		@media(max-width: 768px) {

			.product-card {
				padding: 24px;
			}

			.detail-item {
				flex-direction: column;
				align-items: flex-start;
			}

			.detail-value {
				text-align: left;
			}

			.action-row {
				flex-direction: column;
				align-items: stretch;
			}

			.left-actions,
			.right-actions {
				width: 100%;
				flex-direction: column;
			}

			.btn,
			.delete-form button {
				width: 100%;
			}
		}
	</style>

	<div class="page-container">

		<div class="product-card">

			<div class="product-header">

				<div class="product-title-section">
					<h1>{{ product.name }}</h1>

					<div class="product-subtitle">
						Product Details Overview
					</div>
				</div>

				<div class="product-price-badge">
					₱{{ product.price|number_format(2, '.', ',') }}
				</div>

			</div>

			<div class="product-details">

				<div class="detail-item">
					<div class="detail-label">
						Product ID
					</div>

					<div class="detail-value">
						#{{ product.id }}
					</div>
				</div>

				<div class="detail-item">
					<div class="detail-label">
						Product Name
					</div>

					<div class="detail-value">
						{{ product.name }}
					</div>
				</div>

				<div class="detail-item">
					<div class="detail-label">
						Price
					</div>

					<div class="detail-value">
						₱{{ product.price|number_format(2, '.', ',') }}
					</div>
				</div>

				{% if product.description is defined %}
					<div class="detail-item">
						<div class="detail-label">
							Description
						</div>

						<div class="detail-value">
							{{ product.description }}
						</div>
					</div>
				{% endif %}

			</div>

			<div class="action-row">

				<div class="left-actions">

					<a href="{{ path('app_product_index') }}" class="btn btn-back">
						← Back to Products
					</a>

					<a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-edit">
						✏ Edit Product
					</a>

				</div>

				<div class="right-actions delete-form">
					{{ include('product/_delete_form.html.twig') }}
				</div>

			</div>

		</div>

	</div>
{% endblock %}
