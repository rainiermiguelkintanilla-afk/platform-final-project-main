{% extends 'base.html.twig' %}

{% block title %}New Product
{% endblock %}

{% block body %}
	<style>
		body {
			background: #f4f7fb;
			min-height: 100vh;
			font-family: Inter, sans-serif;
		}

		.page-container {
			max-width: 700px;
			margin: 60px auto;
			padding: 0 20px;
		}

		.product-form-card {
			background: white;
			border-radius: 20px;
			padding: 40px;
			box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
		}

		.product-form-header {
			margin-bottom: 32px;
		}

		.product-form-title {
			font-size: 2rem;
			font-weight: 700;
			color: #0f172a;
			margin-bottom: 8px;
		}

		.product-form-subtitle {
			color: #64748b;
			font-size: 0.95rem;
		}

		.form-group {
			margin-bottom: 20px;
		}

		.form-control,
		input,
		textarea,
		select {
			width: 100%;
			padding: 14px 16px;
			border: 1px solid #dbe2ea;
			border-radius: 12px;
			font-size: 0.95rem;
			transition: all 0.2s ease;
			background: #fff;
		}

		.form-control:focus,
		input:focus,
		textarea:focus,
		select:focus {
			outline: none;
			border-color: #6366f1;
			box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
		}

		label {
			display: block;
			margin-bottom: 8px;
			font-weight: 600;
			color: #334155;
		}

		textarea {
			min-height: 120px;
			resize: vertical;
		}

		.btn-group {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-top: 30px;
			gap: 16px;
		}

		.back-btn {
			text-decoration: none;
			padding: 12px 18px;
			border-radius: 12px;
			background: #eef2ff;
			color: #4f46e5;
			font-weight: 600;
			transition: 0.2s ease;
		}

		.back-btn:hover {
			background: #e0e7ff;
		}

		button,
		.btn,
		.btn-primary {
			background: #4f46e5;
			color: white;
			border: none;
			border-radius: 12px;
			padding: 14px 24px;
			font-weight: 600;
			cursor: pointer;
			transition: 0.2s ease;
			box-shadow: 0 4px 12px rgba(79, 70, 229, 0.18);
		}

		button:hover,
		.btn:hover,
		.btn-primary:hover {
			background: #4338ca;
			transform: translateY(-1px);
		}

		.form-error-message {
			color: #dc2626;
			margin-top: 6px;
			font-size: 0.85rem;
		}

		@media(max-width: 768px) {
			.product-form-card {
				padding: 24px;
			}

			.btn-group {
				flex-direction: column;
				align-items: stretch;
			}

			.back-btn,
			button,
			.btn,
			.btn-primary {
				width: 100%;
				text-align: center;
			}
		}
	</style>

	<div class="page-container">

		<div class="product-form-card">

			<div class="product-form-header">
				<h1 class="product-form-title">
					Create New Product
				</h1>

				<p class="product-form-subtitle">
					Add a new product to your inventory.
				</p>
			</div>

			{{ include('product/_form.html.twig') }}

			<div class="btn-group">
				<a href="{{ path('app_product_index') }}" class="back-btn">
					← Back to Products
				</a>
			</div>

		</div>

	</div>
{% endblock %}
