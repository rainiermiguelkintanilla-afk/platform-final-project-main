{% extends 'base.html.twig' %}

{% block title %}Edit Product
{% endblock %}

{% block body %}
	<style>
		body {
			background: #f4f7fb;
			min-height: 100vh;
			font-family: Inter, sans-serif;
		}

		.page-container {
			max-width: 700px;
			margin: 60px auto;
			padding: 0 20px;
		}

		.product-form-card {
			background: #fff;
			border-radius: 20px;
			padding: 40px;
			box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
		}

		.product-form-header {
			margin-bottom: 32px;
		}

		.product-form-title {
			font-size: 2rem;
			font-weight: 700;
			color: #0f172a;
			margin-bottom: 8px;
		}

		.product-form-subtitle {
			color: #64748b;
			font-size: 0.95rem;
		}

		/* Form Styling */
		.form-group {
			margin-bottom: 20px;
		}

		label {
			display: block;
			margin-bottom: 8px;
			font-weight: 600;
			color: #334155;
		}

		input,
		textarea,
		select,
		.form-control {
			width: 100%;
			padding: 14px 16px;
			border: 1px solid #dbe2ea;
			border-radius: 12px;
			font-size: 0.95rem;
			background: #fff;
			transition: all 0.2s ease;
		}

		input:focus,
		textarea:focus,
		select:focus,
		.form-control:focus {
			outline: none;
			border-color: #6366f1;
			box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
		}

		textarea {
			min-height: 120px;
			resize: vertical;
		}

		/* Buttons */
		.action-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			gap: 16px;
			margin-top: 32px;
			flex-wrap: wrap;
		}

		.left-actions,
		.right-actions {
			display: flex;
			align-items: center;
			gap: 12px;
		}

		.back-btn {
			text-decoration: none;
			padding: 12px 18px;
			border-radius: 12px;
			background: #eef2ff;
			color: #4f46e5;
			font-weight: 600;
			transition: 0.2s ease;
		}

		.back-btn:hover {
			background: #e0e7ff;
		}

		button,
		.btn,
		.btn-primary {
			background: #4f46e5;
			color: white;
			border: none;
			border-radius: 12px;
			padding: 14px 22px;
			font-weight: 600;
			cursor: pointer;
			transition: 0.2s ease;
			box-shadow: 0 4px 12px rgba(79, 70, 229, 0.18);
		}

		button:hover,
		.btn:hover,
		.btn-primary:hover {
			background: #4338ca;
			transform: translateY(-1px);
		}

		/* Delete Button */
		.delete-form button {
			background: #ef4444;
			box-shadow: 0 4px 12px rgba(239, 68, 68, 0.18);
		}

		.delete-form button:hover {
			background: #dc2626;
		}

		/* Errors */
		.form-error-message,
		.invalid-feedback {
			color: #dc2626;
			margin-top: 6px;
			font-size: 0.85rem;
		}

		@media(max-width: 768px) {
			.product-form-card {
				padding: 24px;
			}

			.action-row {
				flex-direction: column;
				align-items: stretch;
			}

			.left-actions,
			.right-actions {
				width: 100%;
				flex-direction: column;
			}

			.back-btn,
			button,
			.btn,
			.btn-primary {
				width: 100%;
				text-align: center;
			}
		}
	</style>

	<div class="page-container">

		<div class="product-form-card">

			<div class="product-form-header">
				<h1 class="product-form-title">
					Edit Product
				</h1>

				<p class="product-form-subtitle">
					Update your product information and save changes.
				</p>
			</div>

			{{ include('product/_form.html.twig', {
            'button_label': 'Update Product'
        }) }}

			<div class="action-row">

				<div class="left-actions">
					<a href="{{ path('app_product_index') }}" class="back-btn">
						← Back to Products
					</a>
				</div>

				<div class="right-actions delete-form">
					{{ include('product/_delete_form.html.twig') }}
				</div>

			</div>

		</div>

	</div>
{% endblock %}
